{
  "expo": {
    "name": "WilderGo",
    "slug": "wildergo",
    "orientation": "portrait",
    "icon": "./assets/images/WilderGo App Icon-iOS-Default-1024x1024@1x.jpg",
    "scheme": "wildergo",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.wildergo.app",
      "icon": "./assets/images/WilderGo App Icon-iOS-Default-1024x1024@1x.jpg",
      "version": "1.0.53",
        "buildNumber": "63",
      "deploymentTarget": "15.1",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSLocationAlwaysAndWhenInUseUsageDescription": "WilderGo uses your location to provide real-time wilderness safety mapping and to relay emergency SOS signals via satellite even when the app is backgrounded.",
        "NSLocationWhenInUseUsageDescription": "WilderGo uses your location to provide real-time wilderness safety mapping and to relay emergency SOS signals via satellite even when the app is backgrounded.",
        "NSLocationAlwaysUsageDescription": "WilderGo uses your location to provide real-time wilderness safety mapping and to relay emergency SOS signals via satellite even when the app is backgrounded.",
        "Privacy - AI Usage Description": "Route optimization is performed on-device to ensure offline privacy."
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.wildergo.app",
      "versionCode": 53,
      "adaptiveIcon": {
        "backgroundColor": "#F5EFE6",
        "foregroundImage": "./assets/images/WilderGo App Icon-iOS-Default-1024x1024@1x.jpg",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F5EFE6",
          "dark": {
            "backgroundColor": "#1E1814"
          }
        }
      ],
      "expo-web-browser",
      [
        "expo-router",
        {
          "origin": false,
          "root": "app"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "reactCompiler": true,
      "typedRoutes": true
    },
    "owner": "jessegcorpus",
    "extra": {
      "router": {
        "origin": false,
        "root": "app"
      },
      "apiBaseUrl": "https://aa60d38e-336a-4c6c-8c7a-2e8f4ae13a3f-00-37dgmtff0mvif.picard.replit.dev",
      "isSOSOfflineEnabled": false,
      "eas": {
        "projectId": "96d7cc3f-fc2d-4e7f-bf65-353eb1a2ccc6"
      }
    }
  }
}
